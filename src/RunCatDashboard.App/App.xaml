<Application x:Class="RunCatDashboard.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <SolidColorBrush x:Key="OverlayPanelBackgroundBrush" Color="#E6262C36" />
        <SolidColorBrush x:Key="OverlayBorderBrush" Color="#807B8794" />
        <SolidColorBrush x:Key="OverlayPrimaryTextBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="OverlaySecondaryTextBrush" Color="#FFD8DEE9" />
        <SolidColorBrush x:Key="OverlayMutedTextBrush" Color="#FFB8C1CC" />
        <SolidColorBrush x:Key="OverlayWarningBrush" Color="#FFFFD580" />
        <SolidColorBrush x:Key="OverlayErrorBrush" Color="#FFFF8A80" />
        <SolidColorBrush x:Key="OverlayModeBackgroundBrush" Color="#FF394453" />
        <SolidColorBrush x:Key="OverlayHistoryBackgroundBrush" Color="#402F3742" />
        <SolidColorBrush x:Key="OverlayRunCatBackgroundBrush" Color="#FFD8DEE9" />
    </Application.Resources>
</Application>
