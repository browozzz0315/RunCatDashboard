<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.10" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\RunCat\cat-frame-01.png;Assets\RunCat\cat-frame-02.png;Assets\RunCat\cat-frame-03.png;Assets\RunCat\cat-frame-04.png;Assets\RunCat\cat-frame-05.png;Assets\RunCat\cat-frame-06.png;Assets\RunCat\cat-frame-07.png;Assets\RunCat\cat-frame-08.png" />
    <EmbeddedResource Include="Assets\RunCat\RunCatDashboard.Tray.ico"
                      LogicalName="RunCatDashboard.App.Assets.RunCat.RunCatDashboard.Tray.ico" />
  </ItemGroup>

</Project>
