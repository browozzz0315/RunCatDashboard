<Window x:Class="RunCatDashboard.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:RunCatDashboard.App.Views"
        mc:Ignorable="d"
        Title="RunCatDashboard"
        Width="430"
        Height="400"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        WindowStyle="None">
    <Window.Resources>
        <views:RunCatFrameConverter x:Key="RunCatFrameConverter" />
    </Window.Resources>
    <Border Margin="8"
            Padding="14"
            Background="{DynamicResource OverlayPanelBackgroundBrush}"
            BorderBrush="{DynamicResource OverlayBorderBrush}"
            BorderThickness="1"
            CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="4,2,4,8"
                    Background="Transparent"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="OnDragSurfaceMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="RunCatDashboard" />
                        <TextBlock Margin="0,2,0,0"
                                   Foreground="{DynamicResource OverlayMutedTextBrush}"
                                   Text="Drag this panel while Interactive" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Padding="10,4"
                            VerticalAlignment="Center"
                            Background="{DynamicResource OverlayModeBackgroundBrush}"
                            CornerRadius="14">
                        <TextBlock Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding OverlayModeText}" />
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Hidden">
                <StackPanel>
                    <Grid Margin="0,2,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource OverlayWarningBrush}"
                                       Text="{Binding OverlayHotKeyText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,2,8,0"
                                       Foreground="{DynamicResource OverlayErrorBrush}"
                                       Text="{Binding OverlayErrorMessage}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,2,8,0"
                                       Foreground="{DynamicResource OverlayErrorBrush}"
                                       Text="{Binding HotKeyErrorMessage}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,2,8,0"
                                       Foreground="{DynamicResource OverlayErrorBrush}"
                                       Text="{Binding TrayErrorMessage}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Padding="10,4"
                                VerticalAlignment="Top"
                                Click="OnCloseButtonClick"
                                Content="Close"
                                Visibility="{Binding IsInteractive, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>

                    <Separator Margin="0,0,0,8" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="98" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="98"
                                Height="66"
                                Background="{DynamicResource OverlayRunCatBackgroundBrush}"
                                BorderBrush="{DynamicResource OverlayBorderBrush}"
                                BorderThickness="1"
                                ClipToBounds="True"
                                CornerRadius="4">
                            <Image Width="64"
                                   Height="64"
                                   HorizontalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   RenderTransformOrigin="0.5,0.5"
                                   SnapsToDevicePixels="True"
                                   Source="{Binding AnimationFrameIndex, Converter={StaticResource RunCatFrameConverter}}"
                                   Stretch="Uniform"
                                   VerticalAlignment="Center">
                                <Image.RenderTransform>
                                    <ScaleTransform ScaleX="2"
                                                    ScaleY="2" />
                                </Image.RenderTransform>
                            </Image>
                        </Border>
                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center">
                            <TextBlock Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="Run Cat" />
                            <TextBlock Margin="0,3,0,0"
                                       Foreground="{DynamicResource OverlaySecondaryTextBrush}"
                                       Text="{Binding AnimationAverageCpuText, StringFormat='3-sample CPU: {0}'}" />
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="{DynamicResource OverlayMutedTextBrush}"
                                       Text="{Binding AnimationIntervalText}" />
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="{DynamicResource OverlayErrorBrush}"
                                       Text="{Binding AnimationErrorMessage}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <Separator Margin="0,0,0,8" />

                    <TextBlock Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                               FontWeight="SemiBold"
                               Text="Fullscreen display policy" />
                    <ComboBox Margin="0,5,0,0"
                              ItemsSource="{Binding DisplayPolicies}"
                              SelectedItem="{Binding RequestedDisplayPolicy, Mode=TwoWay}" />
                    <TextBlock Margin="0,5,0,0"
                               Foreground="{DynamicResource OverlaySecondaryTextBrush}"
                               Text="{Binding AppliedDisplayPolicyText}" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="{DynamicResource OverlaySecondaryTextBrush}"
                               Text="{Binding FullscreenDisplayStatusText}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="{DynamicResource OverlayMutedTextBrush}"
                               Text="{Binding ForegroundDisplayDiagnostic}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="{DynamicResource OverlayMutedTextBrush}"
                               Text="{Binding OverlayMonitorDiagnostic}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,2,0,8"
                               Foreground="{DynamicResource OverlayErrorBrush}"
                               Text="{Binding DisplayPolicyFault}"
                               TextWrapping="Wrap" />

                    <Separator Margin="0,0,0,8" />

                    <TextBlock Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="System Metrics Dashboard" />

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Foreground="{DynamicResource OverlaySecondaryTextBrush}" Text="CPU" />
                        <TextBlock Grid.Column="2"
                                   Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding CpuUsageText}" />

                        <TextBlock Grid.Row="1" Margin="0,5,0,0"
                                   Foreground="{DynamicResource OverlaySecondaryTextBrush}"
                                   Text="Memory" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,5,0,0"
                                   Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding MemoryUsageText}" />

                        <TextBlock Grid.Row="2" Margin="0,5,0,0"
                                   Foreground="{DynamicResource OverlaySecondaryTextBrush}"
                                   Text="Used / Total Memory" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Margin="0,5,0,0"
                                   Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                                   Text="{Binding UsedAndTotalMemoryText}" />

                        <TextBlock Grid.Row="3" Margin="0,5,0,0"
                                   Foreground="{DynamicResource OverlaySecondaryTextBrush}"
                                   Text="Last updated" />
                        <TextBlock Grid.Row="3" Grid.Column="2" Margin="0,5,0,0"
                                   Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                                   Text="{Binding LastUpdatedText}" />

                        <TextBlock Grid.Row="4" Margin="0,5,0,0"
                                   Foreground="{DynamicResource OverlaySecondaryTextBrush}"
                                   Text="Sampling status" />
                        <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,5,0,0">
                            <TextBlock Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                                       Text="{Binding SamplingStatus}" />
                            <TextBlock Foreground="{DynamicResource OverlayErrorBrush}"
                                       Text="{Binding ErrorMessage}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Margin="0,0,0,5"
                                   Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                                   FontWeight="SemiBold"
                                   Text="Recent CPU history (newest to oldest)" />
                        <Border Padding="8"
                                Background="{DynamicResource OverlayHistoryBackgroundBrush}"
                                BorderBrush="{DynamicResource OverlayBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ItemsControl ItemsSource="{Binding CpuHistoryNewestFirst}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,10,4"
                                                   Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                                                   Text="{Binding CpuUsagePercent, StringFormat={}{0:F1}%}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
