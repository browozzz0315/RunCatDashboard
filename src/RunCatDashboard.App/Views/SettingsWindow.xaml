<Window x:Class="RunCatDashboard.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RunCatDashboard 設定" Width="460" Height="470"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        ShowInTaskbar="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <GroupBox Header="Dashboard" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <CheckBox Content="啟動／一般狀態下顯示 Dashboard"
                              IsChecked="{Binding IsDashboardVisible}" Margin="0,0,0,10" />
                    <TextBlock Text="互動模式" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding InteractionModes}"
                              SelectedItem="{Binding InteractionMode}" />
                </StackPanel>
            </GroupBox>
            <GroupBox Header="效能" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Metrics sampling interval（毫秒）" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding SamplingIntervals}"
                              SelectedItem="{Binding SamplingIntervalMilliseconds}" />
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Windows 啟動" Padding="12">
                <StackPanel>
                    <CheckBox Content="登入 Windows 時啟動 RunCatDashboard"
                              IsChecked="{Binding RunAtLoginRequested}" />
                    <TextBlock Margin="0,8,0,0">
                        <Run Text="Applied：" /><Run Text="{Binding RunAtLoginApplied}" />
                    </TextBlock>
                    <TextBlock Text="{Binding StartupFault}" Foreground="DarkRed"
                               TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
            </GroupBox>
            <TextBlock Text="{Binding ValidationError}" Foreground="DarkRed"
                       TextWrapping="Wrap" Margin="0,10,0,0" />
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Command="{Binding CancelCommand}" MinWidth="80" Margin="0,0,8,0" />
            <Button Content="儲存" Command="{Binding SaveCommand}" MinWidth="80" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
